# Allgemeines
# Pflicht fuer npm run und docker compose.
# Passwort fuer Login im Web-UI.
APP_PASSWORD=change-me-now

# Allgemeines (optional)
# Start-Repository relativ zu WORKSPACE_ROOT bzw. /workspace im Container.
# DEFAULT_REPO=pi-mobile

# Optionales Git-Fallback fuer Commits (nur zusammen setzen).
GIT_USER_NAME=Pi Mobile
GIT_USER_EMAIL=pi-mobile@example.com

# Optionales festes Pi-Modell (PI_PROVIDER und PI_MODEL nur zusammen setzen).
# PI_PROVIDER=anthropic
# PI_MODEL=claude-sonnet-4-5
# PI_THINKING_LEVEL=medium

# npm run (ohne Docker)
# Alle Variablen in diesem Block sind optional, weil sinnvolle Defaults existieren.

# Backend bind address (Default: 0.0.0.0).
# HOST=0.0.0.0

# Backend port (Default: 3000).
# PORT=3000

# Root-Verzeichnis fuer Repo-Auswahl (Default: aktuelles Projektverzeichnis).
# WORKSPACE_ROOT=/home/zink/dev

# Pfad fuer persistente Kosten-DB (Default: WORKSPACE_ROOT/.pi-mobile/costs.sqlite).
# COSTS_DB_PATH=/home/zink/dev/.pi-mobile/costs.sqlite

# Cookie-Name fuer Login-Session (Default: pi_mobile_session).
# SESSION_COOKIE_NAME=pi_mobile_session

# Pi-Agent Verzeichnis fuer auth/models (Default: SDK-Standardpfad in HOME).
# PI_AGENT_DIR=/home/zink/.pi/agent

# Pi-Session-Dateien Verzeichnis (Default: SDK-Standardpfad).
# PI_SESSION_DIR=/home/zink/.pi/agent/sessions

# Mock-Mode fuer lokale Tests/Entwicklung (1/true/yes aktiviert).
# PI_MOCK_MODE=1

# Follow-up-Kosten-Guard (global).
# Standard ist aktiviert; kann im Menu ueberschrieben werden.
# VITE_FOLLOW_UP_COST_GUARD_ENABLED=true

# Soft-Limit fuer Follow-up-Schritte (global, USD).
# Wenn ueberschritten, ist vor dem naechsten Follow-up einmalig "Keep running" noetig.
# Default: 0.50; kann im Menu ueberschrieben werden.
# VITE_FOLLOW_UP_COST_SOFT_LIMIT_USD=0.50


# docker compose
# Pflicht nur fuer docker compose.

# Host-Port Mapping auf Container-Port 3000 (Default in compose: 3000).
# HOST_PORT=3000

# Fuer HTTP-Zugriff im Docker-Setup meist false lassen.
# Auf true nur setzen, wenn die App hinter HTTPS laeuft.
# SESSION_COOKIE_SECURE=false

# Host-Pfad, der nach /workspace gemountet wird.
WORKSPACE_HOST_PATH=/home/your-user/dev

# Host-Pfad zu ~/.pi (enthaelt pi auth/session Daten).
PI_HOME_HOST_PATH=/home/your-user/.pi

# Host-Pfad zur gitconfig (read-only in Container).
GITCONFIG_HOST_PATH=/home/your-user/.gitconfig

# Host-Pfad zu SSH-Keys (read-only in Container).
SSH_HOST_PATH=/home/your-user/.ssh

# Optional: explizite Pfade fuer Kosten-DB, Logs und Session-Dateien im Container.
# Standard ist /workspace/pi-mobile/.pi-mobile/* (persistiert im Projektordner).
# COSTS_DB_PATH=/workspace/pi-mobile/.pi-mobile/costs.sqlite
# LOGS_DIR=/workspace/pi-mobile/.pi-mobile/logs
# PI_SESSION_DIR=/workspace/pi-mobile/.pi-mobile/sessions

# UID/GID fuer docker compose (ermittle via `id -u` und `id -g`).
HOST_UID=1000
HOST_GID=1000
