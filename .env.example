# Pflicht (alle Betriebsarten)
APP_PASSWORD=change-me-now

# Pflicht für GIT Zugriff (nur Docker Compose)
SSH_PRIVATE_KEY_FILE=/home/your-user/.ssh/id_ed25519

# Optional (Docker)
HOST_PORT=3000
SESSION_COOKIE_SECURE=false

# Optional (Runtime Defaults)
# DEFAULT_REPO=pi-mobile
# GIT_USER_NAME=Pi Mobile
# GIT_USER_EMAIL=pi-mobile@example.com

# Optional (festes Modell nur zusammen setzen)
# PI_PROVIDER=anthropic
# PI_MODEL=claude-sonnet-4-5
# PI_THINKING_LEVEL=medium

# Optional (nur fuer npm run dev/start ohne Docker)
# WORKSPACE_ROOT=/home/your-user/dev
# COSTS_DB_PATH=/home/your-user/dev/.pi-mobile/costs.sqlite
# LOGS_DIR=/home/your-user/dev/.pi-mobile/logs
# PI_AGENT_DIR=/home/your-user/.pi/agent
# PI_SESSION_DIR=/home/your-user/.pi/agent/sessions
# SESSION_COOKIE_NAME=pi_mobile_session
# HOST=0.0.0.0
# PORT=3000
# PI_MOCK_MODE=1
# VITE_FOLLOW_UP_COST_GUARD_ENABLED=true
# VITE_FOLLOW_UP_COST_SOFT_LIMIT_USD=0.50
